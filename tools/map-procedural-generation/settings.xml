[city]
; avenue/plaza path terrain comes from these template tmx (template/<name>.tmx):
; Walkable fill tile = path terrain, OnGrass 3x3 ring = border. Edit the tmx in
; Tiled to change the terrain. useAsBase=true brushes the tmx itself, centered,
; as the city base ground. signTiles = "tileset/idx" list; ONE style is picked
; per city (signs near the border at the avenue entrances).
big\template=city-big
big\useAsBase=false
big\signTiles="t1.tsx/100,t1.tsx/103"
medium\template=city-medium
medium\useAsBase=false
medium\signTiles="t1.tsx/100"

