[building]
; gymTypes: each gym picks one type; part of the trainer teams comes from the
; type monster pool and the gym facade is recolored with the type color
; (gym-<type> tileset generated into dest/map/tileset/ from tileset/gym.png).
; Colors copied from CatchChallenger-datapack/monsters/type.xml; typeXml can
; point to that file to read them at runtime instead.
gymTypes="fire:#f38233->Panthera fira,Vivicinder;water:#2E9EF3->Dinoflop,Pharfan,Rhinocarpe;plant:#71DA5E->Conileaf,Viviphyta,Cowpignon;poison:#B46DC5->Chenipode,Exapode,Snaki;electric:#FFEC10->Coleorus,Vivitron;stone:#BF904E->Polyrock,Selket,Galnec"
typeXml=
; key-building / bot generation (CatchChallenger-datapack).
; shopItems = numeric item ids that exist in items/items.xml.
; *Skin = a folder NAME under skin/bot (or skin/fighter), NOT an index.
; botSkins = random pool for road/house/trainer NPCs.
botSkins="franck,oldman,florist,farmer,smith,alphonse,captain"
doGym=true
gymLeaderSkin=soldier
gymTrainerSkin=smith
gymTrainers=3
healSkin=oldgirl
shopItems="1,2,3,5,6"
