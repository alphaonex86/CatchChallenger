furniture\table1\layer="Collisions"
furniture\table1\tiles="mobilier/0,mobilier/1,mobilier/32,mobilier/33"  ; TODO pick real pkmn table tiles in normal2
furniture\table1\tags="table"
furniture\table1\width=2
furniture\exit\layer="OnGrass"
furniture\exit\tags="exit"
furniture\exit\template="exit"            ; TODO pkmn template (CC inside-* tileset)
furniture\stairup\template="stair-up"     ; TODO pkmn template
furniture\stairup\tags="stair-up"
furniture\stairup\width=2
furniture\stairup\offsetY=-1
furniture\stairdown\template="stair-down" ; TODO pkmn template
furniture\stairdown\tags="stair-down"
furniture\stairdown\width=2
tileset="terra->normal1.tsx,mobilier->normal2.tsx,wall->tileset-1.tsx,invisible->invisible.tsx"
