; ============================================================================
; settings.xml for datapack-pkmn
;   target: /home/user/Desktop/CatchChallenger/datapack-pkmn
;   place at: <generator run CWD>/settings.xml  (next to dest/map/tileset/)
;
; Tile indices below were DERIVED from the hand-authored gen2 maps after running
; tools/datapack-tileset-deduplicate on datapack-pkmn/map/ (see the repo file
; pkmn-gen2.txt for the per-layer tile-role decode). The gameplay-critical tiles
; (ground / water / tall grass / ledges / collisions / interior floor+walls) are
; data-derived and confident. A few non-essential biome variants (sand/snow/
; mountain ground) reuse plausible tileset-1 ground tiles and are marked
; "; guess". The interior furniture + tree overlays still use the CatchChallenger
; template/ set (which references inside-*/wood tilesets pkmn lacks) — replace
; those with pkmn templates or inline tiles before a fully clean run.
;
; PKMN .tsx live FLAT in map/ (not map/tileset/); stage them into
; <run>/dest/map/tileset/ so these bare names resolve (see DATAPACK-CONFIG.md).
; No usable transition bands -> dotransition=false.
; ============================================================================

[General]
cityRadius=3
displaycity=false
displayregion=false
displayzone=false
doallmap=true
dominimap=true
dotransition=false
dovegetation=true
levelmapmax=50
levelmapmin=2
levelmapscale=0.05
mapHeight=40
mapWidth=40
mapXCount=6
mapYCount=6
maxCityLinks=3
miniMapDivisor=4.0
scale_City=3
scale_TerrainMap=0.03
scale_TerrainMoisure=0.1
scale_Zone=0.1
seed=400
tileStep=4

[plants]
; tree-*.tmx templates reference CC tilesets internally -> wrong tree art for
; pkmn until pkmn tree templates are added. ; TODO pkmn template
tree-1\heightmoisurelist="3,1;3,2;3,3;3,4;3,5;3,6"
tree-1\tmx=tree-1
tree-2\heightmoisurelist="1,1;1,2;1,3;1,4;1,5;1,6;2,1;2,2;2,3;2,4;2,5;2,6"
tree-2\tmx=tree-2

[road]
