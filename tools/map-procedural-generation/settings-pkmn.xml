bot\cashexp=1.5
bot\cashmonster=0.2
bot\dobot=true
bot\maxbot=15
bot\maxskin=474
; ledges: tileset-1 one-way jump tiles (gen2 LedgesDown/Left/Right decode)
ledge\doledge=true
ledge\ledgebottom=740
ledge\ledgechance=0.7
ledge\ledgeleft=710
ledge\ledgeright=711
ledge\tsx=tileset-1.tsx
; overworld tileset alias for region overlays
region\extratileset=ow->tileset-1.tsx
; tall grass (encounter) overlay = tileset-1/32 (gen2 Grass layer decode)
region\grass="grass->ow/32"
region\initialregion=300
region\mountain_layer=Collisions
region\mountain_terrain="mountain,snow"
; impassable mountain/edge collision tiles (gen2 Collisions decode)
region\mountain_tile="961,36,37,38,39,70,71,4,5,68,69"
region\mountain_tsx=ow
region\retrymax=500
region\walkway=""
region\walkwayregion=20
region\waterchance=0.2

[room]
; interiors: floor from normal1, walls from tileset-1, furniture from normal2
