worker_processes 1;
# We launch nginx with `-g "daemon off;"` so the harness owns its
# lifetime via Popen. Setting `daemon` again here would be a duplicate
# directive (rejected by nginx 1.26+); leave it out and rely on the -g
# override.
error_log @PREFIX@/error.log warn;
pid @PREFIX@/nginx.pid;

events {
    worker_connections 64;
}

http {
    access_log @PREFIX@/access.log;
    client_body_temp_path @PREFIX@/client_body;
    proxy_temp_path @PREFIX@/proxy;
    fastcgi_temp_path @PREFIX@/fastcgi;
    uwsgi_temp_path @PREFIX@/uwsgi;
    scgi_temp_path @PREFIX@/scgi;

    default_type application/octet-stream;
    sendfile on;
    keepalive_timeout 30;

    server {
        listen @NGINX_PORT@ default_server;
        server_name localhost;
        root @WWW_ROOT@;
        autoindex on;

        location / {
            try_files $uri $uri/ =404;
        }
    }
}
