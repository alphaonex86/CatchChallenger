  <property name="styleSheet">
   <string notr="true">
    QMainWindow { background-color: #f0f2f5; }
    QListWidget#navList {
      background-color: #1e1e2e;
      color: #cdd6f4;
      border: none;
      font-size: 14px;
      padding: 8px 0;
    }
    QListWidget#navList::item {
      padding: 10px 20px;
      border-left: 3px solid transparent;
    }
    QListWidget#navList::item:selected {
      background-color: #313244;
      border-left: 3px solid #89b4fa;
      color: #cdd6f4;
    }
    QListWidget#navList::item:hover {
      background-color: #282840;
    }
    QStackedWidget { background-color: #ffffff; }
    QLabel { color: #1e1e2e; }
    QGroupBox {
      font-weight: bold;
      border: 1px solid #d0d0d8;
      border-radius: 6px;
      margin-top: 8px;
      padding-top: 16px;
    }
    QGroupBox::title {
      subcontrol-origin: margin;
      left: 12px;
      padding: 0 6px;
      color: #4a4a5a;
    }
    QPushButton {
      background-color: #4a90d9;
      color: white;
      border: none;
      border-radius: 4px;
      padding: 6px 16px;
      font-weight: bold;
    }
    QPushButton:hover { background-color: #5ba0e9; }
    QPushButton:pressed { background-color: #3a80c9; }
    QPushButton:disabled { background-color: #b0b0b0; }
    QPushButton#stopButton { background-color: #d94a4a; }
    QPushButton#stopButton:hover { background-color: #e95b5b; }
    QSpinBox, QDoubleSpinBox, QComboBox, QLineEdit {
      border: 1px solid #d0d0d8;
      border-radius: 4px;
      padding: 4px 8px;
      background-color: #fafafa;
    }
    QSpinBox:focus, QDoubleSpinBox:focus, QComboBox:focus, QLineEdit:focus {
      border: 1px solid #4a90d9;
    }
    QTextEdit, QTextBrowser {
      border: 1px solid #d0d0d8;
      border-radius: 4px;
      background-color: #fafafa;
    }
    QCheckBox { spacing: 6px; }
    QSlider::groove:horizontal {
      border: 1px solid #d0d0d8;
      height: 6px;
      background: #e8e8ee;
      border-radius: 3px;
    }
    QSlider::handle:horizontal {
      background: #4a90d9;
      width: 16px;
      margin: -5px 0;
      border-radius: 8px;
    }
    QFrame.statCard {
      background-color: #ffffff;
      border: 1px solid #e0e0e8;
      border-radius: 8px;
      padding: 10px;
    }
   </string>
